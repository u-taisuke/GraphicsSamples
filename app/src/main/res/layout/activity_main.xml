<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <jp.ac.shohoku.s19bxxx.graphicssamples.CustomView1
        android:id="@+id/customview1"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#E91E63"
        app:layout_constraintTop_toTopOf="parent" />

    <jp.ac.shohoku.s19bxxx.graphicssamples.CustomView2
        android:id="@+id/customview2"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="60dp"
        android:background="#FFEB3B"
        app:layout_constraintEnd_toEndOf="@+id/customview1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/customview1" />

</androidx.constraintlayout.widget.ConstraintLayout>